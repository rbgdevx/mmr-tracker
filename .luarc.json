{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime.version": "Lua 5.1",
  "runtime.nonstandardSymbol": [
    "!=",
    "continue",
    "//"
  ],
  "workspace.ignoreDir": [
    "libs",
    ".libraries",
    ".git",
    ".vscode",
    ".claude"
  ],
  "diagnostics.workspaceDelay": 3000,
  "diagnostics.disable": [
    "lowercase-global",
    "duplicate-set-field",
    "missing-fields",
    "inject-field",
    "cast-local-type",
    "param-type-mismatch",
    "return-type-mismatch"
  ],
  "diagnostics.globals": [
    "MMRTrackerDB",
    "SLASH_MMRT1",
    "SLASH_MMRT2",
    "SlashCmdList",
    "LibStub",
    "CreateFrame",
    "UIParent",
    "UISpecialFrames",
    "C_Timer",
    "C_PvP",
    "C_BattleNet",
    "C_DateAndTime",
    "C_SpecializationInfo",
    "C_AddOns",
    "C_PaperDollInfo",
    "UnitClass",
    "UnitGUID",
    "UnitFullName",
    "IsInInstance",
    "IsShiftKeyDown",
    "GetTime",
    "GetServerTime",
    "GetCurrentRegion",
    "GetInstanceInfo",
    "GetBattlefieldStatus",
    "GetBattlefieldWinner",
    "GetBattlefieldTeamInfo",
    "GetNumBattlefieldScores",
    "GetCurrentArenaSeason",
    "GetPersonalRatedInfo",
    "GetInspectArenaData",
    "GetAddOnMetadata",
    "GetNumClasses",
    "GetClassInfo",
    "GetSpecializationInfoForClassID",
    "SetBattlefieldScoreFaction",
    "hooksecurefunc",
    "CopyTable",
    "format",
    "wipe",
    "tinsert",
    "PVP_RATING",
    "CLOSE",
    "FACTION_HORDE",
    "FACTION_ALLIANCE",
    "VICTORY_TEXT_ARENA0",
    "VICTORY_TEXT_ARENA1",
    "CUSTOM_CLASS_COLORS",
    "RAID_CLASS_COLORS",
    "FauxScrollFrame_Update",
    "FauxScrollFrame_GetOffset",
    "CONQUEST_BUTTONS",
    "ConquestTooltip",
    "ConquestFrame",
    "InspectPVPFrame"
  ],
  "completion.callSnippet": "Replace",
  "completion.keywordSnippet": "Replace",
  "hint.enable": true,
  "hint.setType": true,
  "semantic.enable": true,
  "telemetry.enable": false
}
